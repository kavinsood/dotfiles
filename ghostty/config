# Fonts
font-family = "CommitMono Nerd Font"
font-size = 12
font-feature = liga
font-feature = calt

# Theme
theme = dark:cursor-dark-midnight,light:GitHub

# Window Options
window-padding-x = 0
window-padding-y = 0
adjust-cell-width = -1
adjust-cell-height = -1
window-height=50
window-width=136

# Create splits
keybind = ctrl+shift+(=new_split:right
keybind = ctrl+shift+)=new_split:down
keybind = shift+enter=text:\x1b\r
